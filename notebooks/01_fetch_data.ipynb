    "source": [
     "## 1. Census ACS Demographics + TIGER Geometries"
    ],
    "id": "6R5erHD9EF8M"
   },
   {
    "cell_type": "code",
    "execution_count": 4,
    "metadata": {
     "id": "1PEU2teoEF8M",
     "executionInfo": {
      "status": "ok",
      "timestamp": 1775148000516,
      "user_tz": 240,
      "elapsed": 3664,
      "user": {
       "displayName": "",
       "userId": ""
      }
     },
     "outputId": "6b1e1600-2778-412c-a368-2822d7f3f44a",
     "colab": {
      "base_uri": "https://localhost:8080/"
     }
    },
    "outputs": [
     {
      "output_type": "stream",
      "name": "stdout",
      "text": [
       "Fetching census demographic data...\n",
       "  68 tracts with demographics\n",
       "  Mean pct_no_vehicle: 8.0%\n"
      ]
     }
    ],
    "source": [
     "import requests\n",
     "import geopandas as gpd\n",
     "import pandas as pd\n",
     "from config import RAW_DATA_DIR, CENSUS_API_KEY, CENSUS_VINTAGE, TIGER_VINTAGE, TIGER_TRACTS_LAYER\n",
     "from utils.freshness import write_meta\n",
     "\n",
     "RAW_DATA_DIR.mkdir(parents=True, exist_ok=True)\n",
     "OUTPUT_CENSUS = RAW_DATA_DIR / 'durham_census_tracts.geojson'\n",
     "\n",
     "state_fips = '37'\n",
     "county_fips = '063'\n",
     "base_url = f\"https://api.census.gov/data/{CENSUS_VINTAGE}/acs/acs5\"\n",
     "\n",
     "variables = [\n",
     "    'B01003_001E',  # Total population\n",
     "    'B19013_001E',  # Median household income\n",
     "    'B02001_002E',  # White alone\n",
     "    'B02001_003E',  # Black/African American alone\n",
     "    'B03003_003E',  # Hispanic/Latino\n",
     "    'B08201_001E',  # Total households (vehicle availability denominator)\n",
     "    'B08201_002E',  # Households with no vehicle available\n",
     "    'B08201_003E',  # Households with 1 vehicle available\n",
     "]\n",
     "\n",
     "params = {\n",
     "    'get': ','.join(['NAME'] + variables),\n",
     "    'for': 'tract:*',\n",
     "    'in': f'state:{state_fips} county:{county_fips}',\n",
     "    'key': CENSUS_API_KEY,\n",
     "}\n",
     "\n",
     "print(\"Fetching census demographic data...\")\n",
     "response = requests.get(base_url, params=params)\n",
     "response.raise_for_status()\n",
     "\n",
     "data = response.json()\n",
     "df = pd.DataFrame(data[1:], columns=data[0])\n",
     "df = df.rename(columns={\n",
     "    'B01003_001E': 'total_population',\n",
     "    'B19013_001E': 'median_income',\n",
     "    'B02001_002E': 'white_population',\n",
     "    'B02001_003E': 'black_population',\n",
     "    'B03003_003E': 'hispanic_population',\n",
     "    'B08201_001E': 'total_households',\n",
     "    'B08201_002E': 'households_no_vehicle',\n",
     "    'B08201_003E': 'households_one_vehicle',\n",
     "})\n",
     "\n",
     "numeric_cols = [\n",
     "    'total_population', 'median_income', 'white_population',\n",
     "    'black_population', 'hispanic_population',\n",
     "    'total_households', 'households_no_vehicle', 'households_one_vehicle',\n",
     "]\n",
     "for col in numeric_cols:\n",
     "    df[col] = pd.to_numeric(df[col], errors='coerce')\n",
     "\n",
     "df['pct_white'] = (df['white_population'] / df['total_population'] * 100).round(1)\n",
     "df['pct_black'] = (df['black_population'] / df['total_population'] * 100).round(1)\n",
     "df['pct_hispanic'] = (df['hispanic_population'] / df['total_population'] * 100).round(1)\n",
     "df['pct_minority'] = (100 - df['pct_white']).round(1)\n",
     "\n",
     "# Vehicle availability \u2014 proxy for transit/active transportation dependency.\n",
     "# Car-free households are most likely to walk/cycle but least likely to appear\n",
     "# in Strava data. Source: ACS B08201 (vehicle availability by household).\n",
     "df['pct_no_vehicle'] = (df['households_no_vehicle'] / df['total_households'] * 100).round(1)\n",
     "df['pct_low_vehicle'] = (\n",
     "    (df['households_no_vehicle'] + df['households_one_vehicle'])\n",
     "    / df['total_households'] * 100\n",
     ").round(1)\n",
     "\n",
     "df['tract_id'] = df['state'] + df['county'] + df['tract']\n",
     "\n",
     "print(f\"  {len(df)} tracts with demographics\")\n",
     "print(f\"  Mean pct_no_vehicle: {df['pct_no_vehicle'].mean():.1f}%\")"
    ],
    "id": "1PEU2teoEF8M"
   },
   {
    "cell_type": "code",
